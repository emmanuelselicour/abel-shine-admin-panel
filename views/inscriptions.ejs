<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/jpg" href="https://i.postimg.cc/P5BS0g8h/IMG-20260214-WA0014.jpg">
    <title>Inscriptions | ABEL SHINE</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }
        body {
            background: #f5f5f5;
        }
        .header {
            background: linear-gradient(135deg, #c8a2c8, #d4af37);
            color: white;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .back-btn {
            color: white;
            text-decoration: none;
            background: rgba(255,255,255,0.2);
            padding: 0.5rem 1rem;
            border-radius: 50px;
        }
        .container {
            padding: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }
        .table-container {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow-x: auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            text-align: left;
            padding: 1rem;
            background: #f8f8f8;
            color: #2d2d2d;
            font-weight: 600;
        }
        td {
            padding: 1rem;
            border-bottom: 1px solid #eee;
        }
        tr:hover {
            background: #f9f9f9;
        }
        .status-badge {
            padding: 0.3rem 0.8rem;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 500;
        }
        .status-new {
            background: #e3f2fd;
            color: #1976d2;
        }
        .status-contacted {
            background: #fff3e0;
            color: #f57c00;
        }
        .status-done {
            background: #e8f5e8;
            color: #388e3c;
        }
        .date {
            color: #666;
            font-size: 0.9rem;
        }
        .whatsapp-link {
            color: #25D366;
            text-decoration: none;
            font-weight: 500;
        }
        .whatsapp-link:hover {
            text-decoration: underline;
        }
        .stats {
            margin-bottom: 2rem;
            display: flex;
            gap: 2rem;
        }
        .stat {
            background: white;
            padding: 1rem 2rem;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>📝 Inscriptions reçues</h1>
        <a href="/admin/dashboard" class="back-btn">← Retour</a>
    </div>
    
    <div class="container">
        <div class="stats">
            <div class="stat">
                <strong>Total :</strong> <%= inscriptions.length %> inscriptions
            </div>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Nom complet</th>
                        <th>WhatsApp</th>
                        <th>Email</th>
                        <th>Formation</th>
                        <th>Message</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (inscriptions.length === 0) { %>
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 3rem;">
                                Aucune inscription pour le moment
                            </td>
                        </tr>
                    <% } %>
                    <% inscriptions.forEach(inscription => { %>
                        <tr>
                            <td class="date">
                                <%= new Date(inscription.createdAt).toLocaleDateString('fr-FR', {
                                    day: '2-digit',
                                    month: '2-digit',
                                    year: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit'
                                }) %>
                            </td>
                            <td><strong><%= inscription.nom %></strong></td>
                            <td>
                                <a href="https://wa.me/<%= inscription.whatsapp.replace(/\s/g, '') %>" 
                                   target="_blank" 
                                   class="whatsapp-link">
                                    <%= inscription.whatsapp %>
                                </a>
                            </td>
                            <td><%= inscription.email %></td>
                            <td><%= inscription.formation %></td>
                            <td><%= inscription.message || '-' %></td>
                            <td>
                                <span class="status-badge status-<%= inscription.status === 'Nouveau' ? 'new' : 
                                    (inscription.status === 'Contacté' ? 'contacted' : 'done') %>">
                                    <%= inscription.status %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
