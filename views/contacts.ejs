<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Messages contact | ABEL SHINE</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }
        body {
            background: #f5f5f5;
        }
        .header {
            background: linear-gradient(135deg, #c8a2c8, #d4af37);
            color: white;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .back-btn {
            color: white;
            text-decoration: none;
            background: rgba(255,255,255,0.2);
            padding: 0.5rem 1rem;
            border-radius: 50px;
        }
        .container {
            padding: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }
        .messages-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 2rem;
        }
        .message-card {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border-left: 5px solid <%= contact.status === 'Non lu' ? '#c8a2c8' : '#4caf50' %>;
        }
        .message-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        .message-date {
            color: #666;
            font-size: 0.9rem;
        }
        .message-status {
            padding: 0.3rem 0.8rem;
            border-radius: 50px;
            font-size: 0.9rem;
            background: <%= contact.status === 'Non lu' ? '#ffebee' : '#e8f5e8' %>;
            color: <%= contact.status === 'Non lu' ? '#c62828' : '#2e7d32' %>;
        }
        .message-name {
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }
        .message-contact {
            background: #f5f5f5;
            padding: 1rem;
            border-radius: 10px;
            margin: 1rem 0;
        }
        .message-contact a {
            color: #25D366;
            text-decoration: none;
        }
        .message-content {
            margin: 1rem 0;
            padding: 1rem;
            background: #f9f9f9;
            border-radius: 10px;
            font-style: italic;
        }
        .mark-read {
            background: none;
            border: 2px solid #c8a2c8;
            color: #c8a2c8;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s;
            width: 100%;
            margin-top: 1rem;
        }
        .mark-read:hover {
            background: #c8a2c8;
            color: white;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>📬 Messages de contact</h1>
        <a href="/admin/dashboard" class="back-btn">← Retour</a>
    </div>
    
    <div class="container">
        <div class="messages-grid">
            <% if (contacts.length === 0) { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 3rem;">
                    Aucun message pour le moment
                </div>
            <% } %>
            <% contacts.forEach(contact => { %>
                <div class="message-card" id="message-<%= contact.id %>">
                    <div class="message-header">
                        <span class="message-date">
                            <%= new Date(contact.createdAt).toLocaleDateString('fr-FR', {
                                day: '2-digit',
                                month: '2-digit',
                                year: 'numeric',
                                hour: '2-digit',
                                minute: '2-digit'
                            }) %>
                        </span>
                        <span class="message-status"><%= contact.status %></span>
                    </div>
                    <div class="message-name"><%= contact.nom %></div>
                    <div class="message-contact">
                        <div>📞 <a href="https://wa.me/<%= contact.whatsapp.replace(/\s/g, '') %>" target="_blank">
                            <%= contact.whatsapp %>
                        </a></div>
                        <div>✉️ <%= contact.email %></div>
                    </div>
                    <div class="message-content">
                        <%= contact.message %>
                    </div>
                    <% if (contact.status === 'Non lu') { %>
                        <button class="mark-read" onclick="markAsRead(<%= contact.id %>)">
                            Marquer comme lu
                        </button>
                    <% } %>
                </div>
            <% }) %>
        </div>
    </div>

    <script>
        async function markAsRead(id) {
            try {
                const response = await fetch(`/api/contact/${id}/read`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });
                if (response.ok) {
                    location.reload();
                }
            } catch (error) {
                console.error('Erreur:', error);
            }
        }
    </script>
</body>
</html>
