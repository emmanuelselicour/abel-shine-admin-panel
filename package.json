{
  "name": "abel-shine-admin-panel",
  "version": "2.0.0",
  "description": "Panel d'administration professionnel pour ABEL SHINE École de Cosmétologie - Gestion des inscriptions et messages contact",
  "main": "server.js",
  "author": "ABEL SHINE",
  "license": "UNLICENSED",
  "private": true,
  "keywords": [
    "education",
    "cosmetologie",
    "administration",
    "panel",
    "express",
    "postgresql",
    "sequelize"
  ],
  "engines": {
    "node": "18.x || 20.x || 22.x",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node -e 'require(\"./database.js\").sync({ alter: true })'",
    "db:seed": "node seed.js",
    "test": "echo \"No tests specified\" && exit 0",
    "lint": "eslint server.js database.js routes/",
    "prestart": "npm run db:migrate"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.1",
    "connect-pg-simple": "^9.0.0",
    "ejs": "^3.1.9",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "validator": "^13.11.0",
    "moment": "^2.29.4",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "csrf": "^3.1.0",
    "uuid": "^9.0.1",
    "axios": "^1.6.2",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emmanuelselicour/abel-shine-admin-panel"
  },
  "bugs": {
